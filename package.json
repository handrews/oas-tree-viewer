{
  "name": "oas-tree-viewer",
  "version": "0.9.0",
  "description": "Visualize the parent/child structure of OpenAPI Description (OAD) documents as node-link trees.",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "bench": "VITE_BENCH=1 vitest run --reporter=verbose bench",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@hyperjump/json-schema": "^1.17.6",
    "d3": "^7.9.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.0.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "vitest-browser-svelte": "^2.1.1"
  }
}
