{
  "name": "oas-tree-viewer",
  "version": "0.1.0",
  "description": "Visualize the parent/child structure of OpenAPI Description (OAD) documents as node-link trees.",
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "prepare": "npm run build"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
